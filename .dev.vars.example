# Telegram Bot Credentials (Secrets)
TOKEN=your_telegram_bot_token_here
CHAT_ID=your_telegram_chat_id_here
GOLD_KV_ID=your_gold_kv_here

# Settings
# Minimum price change (VND) to trigger an alert
THRESHOLD=50000
# Number of days to keep for history chart
HISTORY_DAYS=3

# Triggers (Must match wrangler.jsonc manually)
# Note: Cloudflare Cron triggers are defined at deployment in wrangler.jsonc
CRON_SCHEDULE="*/5 * * * *"
